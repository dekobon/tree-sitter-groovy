{
  // markdownlint-cli2 configuration.
  //
  // MD024 `siblings_only` accommodates the Keep a Changelog convention
  // of repeating `### Added` / `### Changed` etc. across version
  // sections. MD013 line-length is widened to 120; tables and code
  // blocks are exempt because their layout is dictated by content, not
  // rewrap-friendly prose. MD033 allows a small set of inline HTML
  // elements that render meaningfully on GitHub (badges, anchor blocks,
  // line breaks, collapsible sections). MD060 (table-column-style) is
  // disabled — tables are content-driven and the bot-aligned style
  // would force noisy padding edits on every column-width change.
  "config": {
    "MD013": {
      "line_length": 120,
      "tables": false,
      "code_blocks": false
    },
    "MD024": {
      "siblings_only": true
    },
    "MD033": {
      // Inline HTML elements that GitHub renders meaningfully and have
      // no clean markdown equivalent. Keep this list narrow: if you
      // reach for <kbd>, <sub>, <sup>, <em>, etc., prefer the markdown
      // equivalent (`**`, `*`, …) and don't extend the allowlist.
      //   a       — anchored links with id= / target="_blank"
      //   img     — README badges and inline diagrams
      //   br      — hard line breaks inside table cells
      //   details — collapsible sections in long READMEs
      //   summary — header row of a <details> block
      "allowed_elements": ["a", "img", "br", "details", "summary"]
    },
    "MD060": false
  },
  "ignores": [
    "target/**",
    "node_modules/**",
    ".claude/**",
    "test/**",
    // docs/** is developer-facing implementation notes (progress
    // checklists, scratch design docs). Lint root-level docs only;
    // docs/** can be cleaned up in a follow-up pass.
    "docs/**"
  ]
}
