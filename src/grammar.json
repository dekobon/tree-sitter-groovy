{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "groovy",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "SYMBOL",
      "name": "identifier"
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_$][A-Za-z0-9_$]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "groovydoc_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_automatic_semicolon"
    },
    {
      "type": "SYMBOL",
      "name": "_slashy_string_start"
    },
    {
      "type": "SYMBOL",
      "name": "_slashy_string_body"
    },
    {
      "type": "SYMBOL",
      "name": "_slashy_string_end"
    },
    {
      "type": "SYMBOL",
      "name": "_dollar_slashy_string"
    },
    {
      "type": "SYMBOL",
      "name": "_gstring_body"
    },
    {
      "type": "SYMBOL",
      "name": "_gstring_interpolation_start"
    },
    {
      "type": "SYMBOL",
      "name": "_label_colon"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "groovydoc_comment"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}